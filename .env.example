# MarkSync — Environment Variables Example
#
# Copy this file to .env.local (gitignored) and fill in your values.
# Never commit credentials. See doc/guides/security-baseline.md.
#
# Lines starting with # are comments. Lines with no value are optional or
# must be provided by the user.

# === Required for live operation ===

# Confluence Cloud tenant URL (your Atlassian site).
MARKSYNC_CONFLUENCE_BASE_URL=

# Confluence user email (part of the API-token auth pair).
MARKSYNC_USER_EMAIL=

# Confluence API token (classic/direct auth — the guaranteed MS-0002 path).
# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
MARKSYNC_API_TOKEN=

# === Optional: configuration overrides ===

# Override the cache root directory (default: .marksync/).
# Must be a path that can be safely deleted; MarkSync never needs it for correctness.
MARKSYNC_CACHE_DIR=

# Override branch restriction (default: ["main"]).
# Comma-separated list of allowed branch names for sync operations.
# CI pipelines may set this to allow sync from non-main branches.
MARKSYNC_ALLOW_BRANCHES=

# === Optional: E2E / live-sandbox test credentials ===
# Only needed for running tests/e2e/ against a real Confluence test space.

MARKSYNC_E2E_CONFLUENCE_BASE_URL=
MARKSYNC_E2E_USER_EMAIL=
MARKSYNC_E2E_API_TOKEN=
MARKSYNC_E2E_SPACE_KEY=
MARKSYNC_E2E_PARENT_PAGE_ID=

# === Optional: debug / development ===

# Log level: trace | debug | info | warn | error (default: info)
MARKSYNC_LOG_LEVEL=

# Disable color output (auto-detected in non-interactive/CI environments).
# Set to "1" to force-disable; "0" to force-enable.
MARKSYNC_NO_COLOR=

# === DO NOT ADD ===
#
# Do NOT add OAuth tokens, refresh tokens, session cookies, or any other
# credential type here. Those belong in the OS keyring (via `marksync login`).
#
# If a new credential type is needed, add it to:
#   1. doc/guides/security-baseline.md (redaction patterns + storage rules)
#   2. doc/guides/dev-environment.md (credential lifecycle)
#   3. This file (the variable name + comment only, never a value)
